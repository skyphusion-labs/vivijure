{
  "name": "vivijure-studio",
  "version": "0.17.2",
  "description": "Vivijure studio core: a module host for AI film production. A thin Cloudflare Worker that owns project / storyboard / cast / render orchestration and a module registry; every capability beyond that is an opt-in module worker plugged in through a typed hook contract.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "dependencies": {
    "@cloudflare/containers": "0.3.7"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:mcp": "wrangler dev -c wrangler.mcp.toml",
    "deploy": "wrangler deploy",
    "deploy:mcp": "wrangler deploy -c wrangler.mcp.toml",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "conformance": "vitest run tests/conformance.test.ts tests/conformance.live.test.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.102.0"
  }
}
