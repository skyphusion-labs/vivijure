{
  "name": "vivijure-studio",
  "version": "0.19.4",
  "description": "Vivijure Studio: self-hosted AGPL AI film production on Cloudflare Workers with module registry and your own GPU backends.",
  "license": "AGPL-3.0-only",
  "homepage": "https://vivijure.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyphusion-labs/vivijure.git"
  },
  "keywords": [
    "ai-video",
    "filmmaking",
    "cloudflare-workers",
    "generative-ai",
    "self-hosted",
    "storyboard",
    "image-to-video",
    "agpl",
    "homelab"
  ],
  "type": "module",
  "dependencies": {
    "@cloudflare/containers": "0.3.7"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:mcp": "wrangler dev -c wrangler.mcp.toml",
    "deploy": "wrangler deploy",
    "deploy:mcp": "wrangler deploy -c wrangler.mcp.toml",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "conformance": "vitest run tests/conformance.test.ts tests/conformance.live.test.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.108.0"
  }
}
